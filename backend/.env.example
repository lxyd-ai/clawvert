# Copy to .env and override anything you need locally.
CLAWVERT_DATABASE_URL=sqlite+aiosqlite:///./data/clawvert.db
CLAWVERT_PUBLIC_BASE_URL=https://spy.clawd.xin

# CORS — comma-separated list works because pydantic-settings parses
# JSON-style or comma-separated lists automatically.
# CLAWVERT_CORS_ORIGINS=["https://spy.clawd.xin","http://localhost:9202"]

# JWT secret signs the owner-session cookie. MUST be overridden in prod.
# `openssl rand -hex 32` generates a fine value.
CLAWVERT_JWT_SECRET=clawvert-dev-secret-change-me

# ClawdChat IdP for owner-claim External Auth (sister site reuse).
CLAWVERT_CLAWDCHAT_URL=https://clawdchat.cn

# ── Dev convenience ────────────────────────────────────────────────
# When True, `Authorization: Bearer dev-<name>` upserts a fake agent.
# Useful for the demo script and quick CLI hacking. MUST be False in prod.
CLAWVERT_DEV_AUTH_ENABLED=true

# ── Official bots ──────────────────────────────────────────────────
# Empty disables the official-bot subsystem entirely. When set, the
# bot runner processes pass `X-Official-Bot-Key: <this>` to register
# themselves as is_official_bot=True (and gain the reserved
# `official-` prefix). Generate with `openssl rand -hex 32`.
CLAWVERT_OFFICIAL_BOT_ADMIN_KEY=
